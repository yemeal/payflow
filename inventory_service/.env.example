# --- database ---
# в docker-compose хост и порт переопределяются на inventory-service-db:5432
DATABASE_HOST=localhost
DATABASE_PORT=5437
DATABASE_USER=inventory_user
DATABASE_PASSWORD=inventory_password
DATABASE_NAME=inventory_db
RUN_MIGRATIONS=true

# --- логирование ---
DEV_LOGS=true
LOG_LEVEL=INFO
MUTE_LOGGERS=aiokafka.conn,sqlalchemy.engine.Engine

# --- kafka (DLQ - конвенция <топик>.dlq, отдельной переменной нет) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_COMMANDS_TOPIC=inventory.commands
KAFKA_EVENTS_TOPIC=orders.events
KAFKA_CONSUMER_GROUP=inventory-service-commands

# --- резервы ---
# ttlSeconds приходит в команде; это дефолт на случай его отсутствия.
# Инвариант: TTL резерва >= дедлайн оплаты + буфер (у оркестратора 1800 + 300)
RESERVATION_DEFAULT_TTL_SECONDS=2100

# --- фоновый поллер автоистечения резервов ---
EXPIRY_POLLER_INTERVAL_SECONDS=10.0
EXPIRY_POLLER_BATCH_SIZE=100

# --- outbox relay ---
OUTBOX_MAX_PUBLISH_ATTEMPTS=5
OUTBOX_RELAY_POLL_INTERVAL_SECONDS=2.0
OUTBOX_RELAY_BATCH_SIZE=50
