{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payflow.contracts.inventory.reserve.v1",
  "title": "inventory.reserve - команда резерва с TTL (inventory.commands)",
  "type": "object",
  "properties": {
    "metadata": {
      "allOf": [{"$ref": "../envelope/command-metadata.v1.schema.json"}],
      "properties": {"commandType": {"const": "inventory.reserve"}},
      "required": ["sagaId", "businessKey"]
    },
    "data": {
      "type": "object",
      "properties": {
        "orderId": {"type": "string", "format": "uuid"},
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "productId": {"type": "string"},
              "quantity": {"type": "integer", "minimum": 1}
            },
            "required": ["productId", "quantity"],
            "additionalProperties": true
          }
        },
        "ttlSeconds": {"type": "integer", "minimum": 1, "description": "Автоистечение резерва; инвариант: ttl >= дедлайн оплаты + буфер"}
      },
      "required": ["orderId", "items", "ttlSeconds"],
      "additionalProperties": true
    }
  },
  "required": ["metadata", "data"]
}
