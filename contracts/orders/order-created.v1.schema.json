{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payflow.contracts.orders.order-created.v1",
  "title": "order.created - стартовое событие саги order-fulfillment (orders.events)",
  "type": "object",
  "properties": {
    "metadata": {
      "allOf": [{"$ref": "../envelope/event-metadata.v1.schema.json"}],
      "properties": {"event_type": {"const": "order.created"}}
    },
    "data": {
      "type": "object",
      "properties": {
        "orderId": {"type": "string", "format": "uuid", "description": "business_key саги и ключ партиционирования"},
        "userId": {"type": "string", "format": "uuid"},
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "productId": {"type": "string"},
              "quantity": {"type": "integer", "minimum": 1},
              "price": {"type": "string", "pattern": "^-?\\d+(\\.\\d+)?$"}
            },
            "required": ["productId", "quantity", "price"],
            "additionalProperties": false
          }
        },
        "totalAmount": {"type": "string", "pattern": "^-?\\d+(\\.\\d+)?$", "description": "Decimal как строка; до появления каталога - от клиента (упрощение MVP)"},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      },
      "required": ["orderId", "userId", "items", "totalAmount", "currency"],
      "additionalProperties": true
    }
  },
  "required": ["metadata", "data"]
}
