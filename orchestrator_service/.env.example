# --- database ---
DATABASE_HOST=localhost
DATABASE_PORT=5436
DATABASE_USER=orchestrator_user
DATABASE_PASSWORD=orchestrator_password
DATABASE_NAME=orchestrator_db
RUN_MIGRATIONS=true

# --- логирование ---
DEV_LOGS=true
LOG_LEVEL=INFO
MUTE_LOGGERS=aiokafka.conn,sqlalchemy.engine.Engine

# --- kafka: топики (DLQ - конвенция <топик>.dlq, отдельной переменной нет) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDERS_EVENTS_TOPIC=orders.events
KAFKA_PAYMENTS_EVENTS_TOPIC=payments.events
KAFKA_INVENTORY_COMMANDS_TOPIC=inventory.commands
KAFKA_PAYMENTS_COMMANDS_TOPIC=payments.commands

# --- kafka: consumer group ---
KAFKA_CONSUMER_GROUP=orchestrator-saga

# --- retry-политика шага саги ---
SAGA_MAX_STEP_ATTEMPTS=3
SAGA_RETRY_BACKOFF_BASE_SECONDS=2.0
SAGA_RETRY_BACKOFF_JITTER=0.2

# --- таймауты шагов ---
SAGA_DEFAULT_STEP_TIMEOUT_SECONDS=30.0
# оплата - human-in-the-loop: пользователь платит до 30 минут
PAYMENT_WAIT_TIMEOUT_SECONDS=1800
# инвариант (итерация 3): TTL резерва >= дедлайн оплаты + буфер (fail-fast на старте)
RESERVATION_TTL_SECONDS=2100
RESERVATION_TTL_BUFFER_SECONDS=300

# --- фоновый поллер (retry + deadline) ---
SAGA_POLLER_INTERVAL_SECONDS=1.0
SAGA_POLLER_BATCH_SIZE=100

# --- outbox relay ---
OUTBOX_MAX_PUBLISH_ATTEMPTS=5
OUTBOX_RELAY_POLL_INTERVAL_SECONDS=2.0
OUTBOX_RELAY_BATCH_SIZE=50

# --- admin api (read-only; секрет общий с auth_service) ---
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256

# --- метрики ---
METRICS_PORT=9100
