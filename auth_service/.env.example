# --- database ---
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=auth_user
DATABASE_PASSWORD=auth_password
DATABASE_NAME=auth_db
RUN_MIGRATIONS=true

# --- логирование ---
DEV_LOGS=true
LOG_LEVEL=INFO
MUTE_LOGGERS=uvicorn.access,sqlalchemy.engine.Engine

# --- redis / HTTP idempotency ---
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_DB=0

# Лок живёт только пока один HTTP refresh обрабатывается.
IDEMPOTENCY_LOCK_TTL=30
# Готовую TokenPair храним недолго: этого достаточно для сетевых retry.
IDEMPOTENCY_RESULT_TTL=300

# --- jwt ---
# закрытый ключ существует только у auth_service и не коммитится
# создать: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:3072 -out secrets/private/access-token.pem
# публичную часть получить отдельно: openssl pkey -in secrets/private/access-token.pem -pubout -out secrets/access-token-public.pem
JWT_PRIVATE_KEY_PATH=./secrets/private/access-token.pem
JWT_PUBLIC_KEY_PATH=./secrets/access-token-public.pem
JWT_ACTIVE_KEY_ID=auth-2026-07
JWT_ISSUER=payflow-auth
JWT_SERVICE_AUDIENCE=auth-service
JWT_AUDIENCES=auth-service,order-service,orchestrator-service
JWT_CLOCK_SKEW_SECONDS=30
ACCESS_TOKEN_TTL_SECONDS=900

# Сессия истекает только после этого периода без успешного refresh.
# Каждый успешный refresh продлевает ту же сессию еще на 30 дней.
# Абсолютного TTL сессии и отдельного TTL у одноразового refresh-токена нет.
AUTH_SESSION_IDLE_TTL_SECONDS=2592000
