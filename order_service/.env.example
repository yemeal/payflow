# --- database ---
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USER=order_user
DATABASE_PASSWORD=order_password
DATABASE_NAME=order_db
RUN_MIGRATIONS=true

# --- логирование ---
DEV_LOGS=true
LOG_LEVEL=INFO
MUTE_LOGGERS=uvicorn.access,aiokafka.conn,sqlalchemy.engine.Engine

# --- redis (кэш статусов заказов; db=2, чтобы не пересекаться с payment=0 и analytics=1) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
ORDER_CACHE_TTL_SECONDS=60

# --- jwt (проверка access-токенов, выданных auth_service) ---
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256

# --- kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVENTS_TOPIC=orders.events
KAFKA_EVENTS_DLQ_TOPIC=orders.events.dlq
KAFKA_CONSUMER_GROUP=order-service-saga-events

# --- outbox ---
OUTBOX_MAX_PUBLISH_ATTEMPTS=5
