# --- логирование ---
DEV_LOGS=true
LOG_LEVEL=INFO
MUTE_LOGGERS=aiokafka.conn

# --- kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# конвенция contracts/README: парный <топик>.dlq у каждого рабочего топика
KAFKA_DLQ_PATTERN=.*\.dlq$
KAFKA_CONSUMER_GROUP=dlq-watcher

# --- метрики ---
METRICS_PORT=9100
